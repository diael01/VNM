{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "File": {
      "Enabled": false,
      "RootPath": "Logs",
      "RetainedFileCountLimit": 3,
      "FileSizeLimitBytes": 10485760
    }
  },
  "AllowedHosts": "*",
  "RabbitMQ": {
    "Host": "localhost",
    "VirtualHost": "/",
    "Username": "guest"
  },
  "EventBus": {
    "QueueName": "meter-ingestion-queue",
    "Retry": {
      "Count": 5,
      "IntervalSeconds": 10
    },
    "Redelivery": {
      "IntervalsSeconds": "10,30,60,120"
    }
  },
  "Authentication": {
    "Authority": "https://localhost:5001",
    "ClientId": "vnm-meter-ingestion",
    "ClientSecret": "meter-ingestion-secret",
    "Scope": "inverter.read"
    },
    "DailyBalanceComputation": {
      "Enabled": true,   
      "IntervalMinutes": 1
    },
     "Metering": {
      "ReadingIntervalMinutes": 1
     },
    "TransferWorkflow": {
        "Enabled": true,
        "PollIntervalSeconds": 60
      },
    "TransferWorkflowCleanup": {
    "ExpirationDays": 30,
    "RunIntervalMinutes": 1440
  }

}

