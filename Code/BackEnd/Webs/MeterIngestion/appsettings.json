{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "File": {
      "Enabled": false,
      "RootPath": "Logs",
      "RetainedFileCountLimit": 3,
      "FileSizeLimitBytes": 10485760
    }
  },
  "AllowedHosts": "*",
  "RabbitMQ": {
    "Host": "localhost",
    "VirtualHost": "/",
    "Username": "guest"
  },
  "EventBus": {
    "Retry": {
      "Count": 5,
      "IntervalSeconds": 10
    },
    "Redelivery": {
      "IntervalsSeconds": "10,30,60,120"
    }
  }
}
